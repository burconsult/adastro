# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Local Supabase (optional, used by Supabase CLI)
LOCAL_SUPABASE_URL=http://127.0.0.1:54321
LOCAL_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
LOCAL_SUPABASE_SECRET_KEY=your-secret-key

# Site Configuration
SITE_URL=http://localhost:4321

# Storage / CDN
MEDIA_STORAGE_BUCKET=
MIGRATION_UPLOADS_BUCKET=
IMAGE_CDN_PROVIDER=vercel # supabase | cloudflare | custom
IMAGE_CDN_BASE_URL=
IMAGE_CDN_API_KEY=
IMAGE_CDN_ZONE_ID=

# AI Providers
OPENAI_API_KEY=
GOOGLE_GENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
# Provider/model settings are configured in Admin → Settings → AI & Automation.

# AdAstro MCP Server (optional)
MCP_SERVER_TOKEN=
