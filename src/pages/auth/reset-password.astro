---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sanitizeRedirectPath } from "@/lib/auth/redirects";
import { getLocaleMessages, t } from "@/lib/i18n/runtime";
import { getSiteLocaleConfig } from "@/lib/site-config";
import { normalizeLocaleCode } from "@/lib/i18n/locales";
import resetPasswordScriptUrl from "@/lib/client/auth/reset-password.js?url";

const nextPath = sanitizeRedirectPath(Astro.url.searchParams.get('next'), '/profile');
const localeConfig = await getSiteLocaleConfig();
const locale = normalizeLocaleCode(Astro.locals.locale, localeConfig.defaultLocale);
const localeMessages = getLocaleMessages(locale);
const resetPasswordClientMessages = {
  linkFailedPrefix: t(localeMessages, 'core.auth.reset.linkFailedPrefix', 'Password reset link failed:'),
  invalidLink: t(localeMessages, 'core.auth.reset.invalidLink', 'Your reset link is invalid or expired. Request a new one.'),
  signInFirst: t(localeMessages, 'core.auth.reset.signInFirst', 'Sign in first or request a new password reset link.'),
  sessionVerified: t(localeMessages, 'core.auth.reset.sessionVerified', 'Session verified. Set your new password below.'),
  passwordTooShort: t(localeMessages, 'core.auth.reset.passwordTooShort', 'Password must be at least 8 characters.'),
  passwordMismatch: t(localeMessages, 'core.auth.reset.passwordMismatch', 'Password confirmation does not match.'),
  updateFailed: t(localeMessages, 'core.auth.reset.updateFailed', 'Unable to update password.'),
  updateFailedTitle: t(localeMessages, 'core.auth.reset.updateFailedTitle', 'Password update failed'),
  updatedStatus: t(localeMessages, 'core.auth.reset.updatedStatus', 'Password updated. Redirecting...'),
  updatedTitle: t(localeMessages, 'core.auth.reset.updatedTitle', 'Password updated'),
  updatedBody: t(localeMessages, 'core.auth.reset.updatedBody', 'Your password was updated successfully.'),
  updateFailedDefault: t(localeMessages, 'core.auth.reset.updateFailedDefault', 'Unable to update password right now.'),
  finalizeSessionFailed: t(localeMessages, 'core.auth.reset.finalizeSessionFailed', 'Failed to finalize reset session.')
};
---

<BaseLayout
  title={t(localeMessages, 'core.auth.reset.title', 'Set password')}
  description={t(localeMessages, 'core.auth.reset.description', 'Create or reset your account password')}
>
  <div class="min-h-[calc(100vh-8rem)] flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <div class="card p-8" id="reset-password-root" data-next-target={nextPath}>
        <div class="text-center mb-6">
          <img src="/logo.svg" alt="" class="h-12 w-12 mx-auto mb-4" />
          <h1 class="text-2xl font-bold">{t(localeMessages, 'core.auth.reset.heading', 'Set your password')}</h1>
          <p class="text-muted-foreground mt-2 text-sm">
            {t(localeMessages, 'core.auth.reset.body', 'Choose a secure password for your account.')}
          </p>
        </div>

        <form id="reset-password-form" class="space-y-4 hidden">
          <div>
            <label for="password" class="block text-sm font-medium mb-2">{t(localeMessages, 'core.auth.reset.newPassword', 'New password')}</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              autocomplete="new-password"
              class="w-full px-3 py-2 border border-input rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder={t(localeMessages, 'core.auth.reset.newPasswordPlaceholder', 'At least 8 characters')}
            />
          </div>

          <div>
            <label for="confirm-password" class="block text-sm font-medium mb-2">{t(localeMessages, 'core.auth.reset.confirmPassword', 'Confirm password')}</label>
            <input
              type="password"
              id="confirm-password"
              name="confirm-password"
              required
              minlength="8"
              autocomplete="new-password"
              class="w-full px-3 py-2 border border-input rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder={t(localeMessages, 'core.auth.reset.confirmPasswordPlaceholder', 'Repeat password')}
            />
          </div>

          <button type="submit" id="submit-btn" class="w-full btn btn-primary">
            <span id="submit-text">{t(localeMessages, 'core.auth.reset.submit', 'Update password')}</span>
            <span id="submit-loading" class="hidden">{t(localeMessages, 'core.auth.reset.submitting', 'Updating...')}</span>
          </button>
        </form>

        <p id="reset-password-status" class="mt-4 text-sm text-muted-foreground">
          {t(localeMessages, 'core.auth.reset.verifying', 'Verifying secure link...')}
        </p>

        <div class="mt-6 text-center">
          <a href="/auth/login" class="text-sm text-muted-foreground hover:text-foreground">
            {t(localeMessages, 'core.auth.reset.returnToLogin', 'Return to login')}
          </a>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="auth-reset-messages" set:html={JSON.stringify(resetPasswordClientMessages)}></script>
  <script type="module" src={resetPasswordScriptUrl}></script>
</BaseLayout>
