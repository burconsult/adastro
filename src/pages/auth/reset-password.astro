---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sanitizeRedirectPath } from "@/lib/auth/redirects";

const nextPath = sanitizeRedirectPath(Astro.url.searchParams.get('next'), '/profile');
---

<BaseLayout title="Set Password" description="Create or reset your account password">
  <div class="min-h-[calc(100vh-8rem)] flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <div class="card p-8" id="reset-password-root" data-next-target={nextPath}>
        <div class="text-center mb-6">
          <img src="/logo.svg" alt="" class="h-12 w-12 mx-auto mb-4" />
          <h1 class="text-2xl font-bold">Set your password</h1>
          <p class="text-muted-foreground mt-2 text-sm">
            Choose a secure password for your account.
          </p>
        </div>

        <form id="reset-password-form" class="space-y-4 hidden">
          <div>
            <label for="password" class="block text-sm font-medium mb-2">New password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              autocomplete="new-password"
              class="w-full px-3 py-2 border border-input rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="At least 8 characters"
            />
          </div>

          <div>
            <label for="confirm-password" class="block text-sm font-medium mb-2">Confirm password</label>
            <input
              type="password"
              id="confirm-password"
              name="confirm-password"
              required
              minlength="8"
              autocomplete="new-password"
              class="w-full px-3 py-2 border border-input rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="Repeat password"
            />
          </div>

          <button type="submit" id="submit-btn" class="w-full btn btn-primary">
            <span id="submit-text">Update password</span>
            <span id="submit-loading" class="hidden">Updating...</span>
          </button>
        </form>

        <p id="reset-password-status" class="mt-4 text-sm text-muted-foreground">
          Verifying secure link...
        </p>

        <div class="mt-6 text-center">
          <a href="/auth/login" class="text-sm text-muted-foreground hover:text-foreground">
            Return to login
          </a>
        </div>
      </div>
    </div>
  </div>

  <script src="/scripts/reset-password.js" defer is:inline></script>
</BaseLayout>
