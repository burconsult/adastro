---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { authService } from "@/lib/auth/auth-helpers";
import { sanitizeRedirectPath } from "@/lib/auth/redirects";
import { getOAuthProviderAvailability } from "@/lib/auth/oauth-providers";
import loginScriptUrl from "@/lib/client/auth/login.js?url";

const rawRedirect = Astro.url.searchParams.get('redirect') || '/admin';
const redirect = sanitizeRedirectPath(rawRedirect, '/admin');
const currentUser = await authService.getUserFromRequest(Astro.request);
if (currentUser) {
  const redirectTarget = redirect.startsWith('/auth/login')
    ? (currentUser.role === 'admin' ? '/admin' : '/profile')
    : redirect;
  const destination = redirectTarget.startsWith('/admin') && currentUser.role !== 'admin'
    ? '/profile'
    : redirectTarget;
  return Astro.redirect(destination);
}
const error = Astro.url.searchParams.get('error');
const oauthProviders = (await getOAuthProviderAvailability()).filter((provider) => provider.available);
---

<BaseLayout title="Sign In" description="Sign in to your AdAstro account">
  <div class="min-h-[calc(100vh-8rem)] flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <div class="card p-8">
        <div class="text-center mb-8">
          <img src="/logo.svg" alt="" class="h-12 w-12 mx-auto mb-4" />
          <h1 class="text-2xl font-bold">Sign In</h1>
          <p class="text-muted-foreground mt-2">Sign in to access your dashboard and profile</p>
        </div>

        {error && (
          <div class="mb-6 p-4 bg-destructive/10 border border-destructive/20 rounded-md">
            <p class="text-sm text-destructive">
              {error === 'auth_error' && 'Authentication error occurred. Please try again.'}
              {error === 'unauthorized' && 'You do not have permission to access the admin area.'}
              {error === 'session_expired' && 'Your session has expired. Please log in again.'}
              {error === 'oauth_provider_unavailable' && 'Social sign-in is currently unavailable. Use email and password or enable OAuth in settings.'}
            </p>
          </div>
        )}

        <form id="login-form" class="space-y-6" data-redirect={redirect}>
          {oauthProviders.length > 0 && (
            <>
              <div class="grid gap-3">
                {oauthProviders.map((provider) => (
                  <a href={`/auth/oauth/${provider.id}?redirect=${encodeURIComponent(redirect)}`} class="w-full btn btn-outline">
                    Continue with {provider.label}
                  </a>
                ))}
              </div>

              <div class="relative">
                <div class="absolute inset-0 flex items-center" aria-hidden="true">
                  <div class="w-full border-t border-border"></div>
                </div>
                <div class="relative flex justify-center text-xs uppercase">
                  <span class="bg-card px-2 text-muted-foreground">Or use email and password</span>
                </div>
              </div>
            </>
          )}

          <div>
            <label for="email" class="block text-sm font-medium mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              class="w-full px-3 py-2 border border-input rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium mb-2">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
              required
              class="w-full px-3 py-2 border border-input rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="••••••••"
            />
          </div>

          <div class="flex items-center justify-between">
            <label class="flex items-center">
              <input type="checkbox" id="remember" name="remember" class="mr-2" />
              <span class="text-sm text-muted-foreground">Remember me</span>
            </label>
            <a href="/auth/forgot-password" class="text-sm text-primary hover:underline">
              Forgot password?
            </a>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full btn btn-primary"
            disabled
          >
            <span id="submit-text">Sign In</span>
            <span id="submit-loading" class="hidden">Signing in...</span>
          </button>
        </form>

        <p class="mt-4 text-center text-xs text-muted-foreground">
          Invited user? Use the invite email link to set your password.
          <a href="/auth/forgot-password" class="text-primary hover:underline">Need a new link?</a>
        </p>

        <div class="mt-6 text-center">
          <a href="/" class="text-sm text-muted-foreground hover:text-foreground">
            ← Back to site
          </a>
        </div>
      </div>
    </div>
  </div>

  <script type="module" src={loginScriptUrl}></script>
</BaseLayout>
