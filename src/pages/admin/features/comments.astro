---
import AdminLayout from '@/layouts/AdminLayout.astro';
import AdminPageHeader from '@/components/admin/AdminPageHeader.astro';
import CommentsFeatureDashboard from '@/lib/components/admin/CommentsFeatureDashboard';
import { isFeatureActive } from '@/lib/features/state';
import { getSiteContentRouting } from '@/lib/site-config';

const commentsActive = await isFeatureActive('comments');
if (!commentsActive) {
  return Astro.redirect('/admin/features');
}
const contentRouting = await getSiteContentRouting();
---

<AdminLayout title="Comments" description="Configure comment moderation and anti-spam controls">
  <div class="space-y-6">
    <AdminPageHeader
      title="Comments"
      description="Manage comment moderation rules and review the pending queue."
    >
      <a href="/admin/features" class="btn btn-outline" slot="actions">
        ← Back to Features
      </a>
    </AdminPageHeader>
    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        Comments management requires JavaScript. Please enable it to continue.
      </div>
    </noscript>

    <CommentsFeatureDashboard
      client:load
      articleBasePath={contentRouting.articleBasePath}
      articlePermalinkStyle={contentRouting.articlePermalinkStyle}
    />
  </div>
</AdminLayout>
