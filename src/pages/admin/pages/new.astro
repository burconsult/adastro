---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
import { AuthorRepository } from "@/lib/database/repositories/author-repository";
import { PageEditor } from "@/lib/components/PageEditor.tsx";
import { SettingsService } from "@/lib/services/settings-service";

const user = Astro.locals.user;
const isAdmin = user?.role === 'admin';
const authorId = user?.authorId;

let authors: any[] = [];
let defaultLocale = 'en';
let supportedLocales: string[] = ['en'];

try {
  const authorRepo = new AuthorRepository(true);
  const settingsService = new SettingsService();
  const [authorResults, localeSettings] = await Promise.all([
    authorRepo.findAll(),
    settingsService.getSettings(['content.defaultLocale', 'content.locales'])
  ]);
  authors = authorResults;
  defaultLocale = typeof localeSettings['content.defaultLocale'] === 'string'
    ? localeSettings['content.defaultLocale']
    : 'en';
  supportedLocales = Array.isArray(localeSettings['content.locales'])
    ? localeSettings['content.locales'].filter((entry) => typeof entry === 'string' && entry.trim().length > 0)
    : ['en'];
  if (!supportedLocales.includes(defaultLocale)) {
    supportedLocales.unshift(defaultLocale);
  }

  if (!isAdmin && authorId) {
    authors = authors.filter((author) => author.id === authorId);
  }
} catch (error) {
  console.error('Error loading authors:', error);
}
---

<AdminLayout title="New Page" description="Create a new page">
  <div class="space-y-6">
    <AdminPageHeader title="New Page" description="Create a new page">
      <a href="/admin/pages" class="btn btn-outline" slot="actions">
        ← Back to Pages
      </a>
    </AdminPageHeader>

    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        Page editor requires JavaScript. Please enable it to continue.
      </div>
    </noscript>

    <PageEditor
      client:load
      mode="create"
      authors={JSON.parse(JSON.stringify(authors, (_key, value) => value instanceof Date ? value.toISOString() : value))}
      defaultLocale={defaultLocale}
      supportedLocales={supportedLocales}
    />
  </div>
</AdminLayout>
