---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
import { PageRepository } from "@/lib/database/repositories/page-repository";
import { AuthorRepository } from "@/lib/database/repositories/author-repository";
import { PageEditor } from "@/lib/components/PageEditor.tsx";

const { id } = Astro.params;
const user = Astro.locals.user;
const isAdmin = user?.role === 'admin';
const authorId = user?.authorId;

if (!id) {
  return Astro.redirect('/admin/pages');
}

let page: any = null;
let authors: any[] = [];
let pageHref = '/';

try {
  const pageRepo = new PageRepository(true);
  const authorRepo = new AuthorRepository(true);
  const [pageResult, authorResults] = await Promise.all([
    pageRepo.findByIdWithRelations(id),
    authorRepo.findAll()
  ]);

  page = pageResult;
  authors = authorResults;
  pageHref = page?.slug === 'home' ? '/' : `/${page?.slug}`;

  if (!page || (!isAdmin && page.author?.id !== authorId)) {
    return Astro.redirect('/admin/pages');
  }

  if (!isAdmin && authorId) {
    authors = authors.filter((author) => author.id === authorId);
  }
} catch (error) {
  console.error('Error loading page:', error);
  return Astro.redirect('/admin/pages');
}
---

<AdminLayout title={`Edit: ${page.title}`} description="Edit page">
  <div class="space-y-6">
    <AdminPageHeader title="Edit Page" description={page.title}>
      <a href={pageHref} target="_blank" rel="noreferrer" class="btn btn-outline" slot="actions">
        View Page
      </a>
      <a href="/admin/pages" class="btn btn-outline" slot="actions">
        ← Back to Pages
      </a>
    </AdminPageHeader>

    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        Page editor requires JavaScript. Please enable it to continue.
      </div>
    </noscript>

    <PageEditor
      client:load
      mode="edit"
      page={JSON.parse(JSON.stringify(page, (_key, value) => value instanceof Date ? value.toISOString() : value))}
      authors={JSON.parse(JSON.stringify(authors, (_key, value) => value instanceof Date ? value.toISOString() : value))}
    />
  </div>
</AdminLayout>
