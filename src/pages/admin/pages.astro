---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
import PageListing from "@/lib/components/PageListing";
import { PageRepository } from "@/lib/database/repositories/page-repository";
import { SettingsService } from "@/lib/services/settings-service";
import { Plus } from "lucide-react";

const user = Astro.locals.user;
const isAdmin = user?.role === 'admin';
const authorId = user?.authorId;

let initialPages: any[] = [];
let defaultLocale = 'en';
let supportedLocales: string[] = ['en'];

try {
  const pageRepo = new PageRepository(true);
  const settingsService = new SettingsService();
  const [result, localeSettings] = await Promise.all([
    pageRepo.findWithFilters({
      limit: 20,
      authorId: !isAdmin ? authorId : undefined
    }),
    settingsService.getSettings(['content.defaultLocale', 'content.locales'])
  ]);
  initialPages = Array.isArray(result) ? result : result.pages || [];
  defaultLocale = typeof localeSettings['content.defaultLocale'] === 'string'
    ? localeSettings['content.defaultLocale']
    : 'en';
  supportedLocales = Array.isArray(localeSettings['content.locales'])
    ? localeSettings['content.locales'].filter((entry) => typeof entry === 'string' && entry.trim().length > 0)
    : ['en'];
  if (!supportedLocales.includes(defaultLocale)) {
    supportedLocales.unshift(defaultLocale);
  }
} catch (error) {
  console.error('Error loading pages:', error);
}
---

<AdminLayout title="Pages" description="Manage site pages">
  <div class="space-y-6">
    <AdminPageHeader title="Pages" description="Create and edit site pages">
      <a href="/admin/pages/new" class="btn btn-primary" slot="actions">
        <Plus className="mr-2 h-4 w-4" />
        New Page
      </a>
    </AdminPageHeader>

    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        Page management requires JavaScript. Please enable it to continue.
      </div>
    </noscript>

    <PageListing
      client:load
      initialPages={JSON.parse(JSON.stringify(initialPages, (_key, value) => value instanceof Date ? value.toISOString() : value))}
      defaultLocale={defaultLocale}
      supportedLocales={supportedLocales}
    />
  </div>
</AdminLayout>
