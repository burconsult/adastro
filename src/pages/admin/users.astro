---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
import UserManager from "@/lib/components/UserManager";
---

<AdminLayout title="User Management" description="Manage user accounts and permissions">
  <div class="space-y-6">
    <AdminPageHeader title="Users" description="Manage user accounts, roles, and profile details." />
    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        User management requires JavaScript. Please enable it to continue.
      </div>
    </noscript>
    <UserManager client:load />
  </div>
</AdminLayout>
