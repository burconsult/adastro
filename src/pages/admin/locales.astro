---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
import LocaleManager from "@/lib/components/LocaleManager";
---

<AdminLayout title="Locales" description="Manage public multilingual configuration and translation pack health.">
  <div class="space-y-6">
    <AdminPageHeader
      title="Locales"
      description="Manage public multilingual activation, default locale routing, and translation pack health across core and bundled features."
    />
    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        Locale management requires JavaScript. Please enable it to manage multilingual settings.
      </div>
    </noscript>
    <LocaleManager client:load />
  </div>
</AdminLayout>
