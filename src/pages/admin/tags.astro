---
import AdminLayout from "@/layouts/AdminLayout.astro";
import TagManager from "@/lib/components/TagManager";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
---

<AdminLayout title="Tags" description="Manage your blog tags">
  <div class="space-y-6">
    <AdminPageHeader title="Tags" description="Curate searchable keywords and content filters." />
    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        Tag management requires JavaScript. Please enable it to manage tags.
      </div>
    </noscript>
    <TagManager client:load />
  </div>
</AdminLayout>
