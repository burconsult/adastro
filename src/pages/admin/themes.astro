---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminPageHeader from "@/components/admin/AdminPageHeader.astro";
import { ThemeManager } from "@/lib/components/ThemeManager";
---

<AdminLayout title="Themes" description="Install and manage appearance themes">
  <div class="space-y-6">
    <AdminPageHeader title="Themes" description="Preview, activate, and install themes." />
    <noscript>
      <div class="rounded-lg border border-destructive/20 bg-destructive/10 p-4 text-sm text-destructive">
        Theme management requires JavaScript. Please enable it to manage themes.
      </div>
    </noscript>
    <ThemeManager client:load />
  </div>
</AdminLayout>
