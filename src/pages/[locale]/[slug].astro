---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageRenderer from "@/components/PageRenderer.astro";
import { getPublishedPageBySlug } from "@/lib/database/index.js";
import { getSiteIdentity, getSiteLocaleConfig } from "@/lib/site-config";
import type { Page } from "@/lib/types/index.js";
import { normalizeLocaleCode } from "@/lib/i18n/locales";

const rawLocale = Astro.params.locale || '';
const localeConfig = await getSiteLocaleConfig();
const locale = normalizeLocaleCode(rawLocale, localeConfig.defaultLocale);
if (!localeConfig.locales.includes(locale) || rawLocale !== locale) {
  return new Response(null, { status: 404 });
}

const { slug } = Astro.params;
if (slug?.includes('.')) {
  return Astro.redirect('/404');
}

const page = await getPublishedPageBySlug(slug!, { locale, includeFallback: false });

if (!page) {
  return new Response(null, { status: 404 });
}

const siteIdentity = await getSiteIdentity();
const pageTitle = page.seoMetadata?.metaTitle || page.title;
const pageDescription = page.seoMetadata?.metaDescription || page.excerpt || siteIdentity.description;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <PageRenderer page={page as Page} />
</BaseLayout>
