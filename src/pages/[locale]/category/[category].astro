---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogPostGrid from "@/components/BlogPostGrid.astro";
import { getCategoriesWithPosts, getLocalizedCategoryBySlug, getPostsByCategory } from "@/lib/database/index.js";
import { getSiteContentPreferences, getSiteContentRouting, getSiteLocaleConfig } from "@/lib/site-config";
import { buildArticlesIndexPath } from "@/lib/routing/articles";
import { buildLocalizedPath, normalizeLocaleCode } from "@/lib/i18n/locales";
import { getLocaleMessages, t } from "@/lib/i18n/runtime";

const rawLocale = Astro.params.locale || '';
const localeConfig = await getSiteLocaleConfig();
const locale = normalizeLocaleCode(rawLocale, localeConfig.defaultLocale);
if (!localeConfig.locales.includes(locale) || rawLocale !== locale) {
  return new Response(null, { status: 404 });
}
const localeMessages = getLocaleMessages(locale);

const { category: categorySlug } = Astro.params;
const category = categorySlug ? await getLocalizedCategoryBySlug(categorySlug, locale) : null;

if (!category) {
  return new Response(null, { status: 404 });
}

const contentPreferences = await getSiteContentPreferences();
const posts = await getPostsByCategory(category.slug, contentPreferences.postsPerPage, 0, locale);
const contentRouting = await getSiteContentRouting();
const articlesIndexPath = buildArticlesIndexPath({
  basePath: contentRouting.articleBasePath,
  permalinkStyle: contentRouting.articlePermalinkStyle,
  localePrefix: locale
});
const sidebarCategories = (await getCategoriesWithPosts(locale))
  .filter((item) => item.slug !== category.slug)
  .slice(0, 6);
const pageDescription = category.description
  || `${t(localeMessages, 'core.category.descriptionPrefix', 'Posts in the')} "${category.name}".`;
---
<BaseLayout
  title={`${t(localeMessages, 'core.category.titlePrefix', 'Posts in')} ${category.name}`}
  description={pageDescription}
>
  <div class="min-h-screen">
    <div class="mx-auto max-w-6xl px-6 py-10 sm:px-8 sm:py-14">
      <header class="mb-12 text-center">
        <div class="flex items-center justify-center gap-2 text-sm mb-4 text-muted-foreground">
          <a href={buildLocalizedPath('/', locale)} class="transition-colors hover:text-foreground">{t(localeMessages, 'core.nav.home', 'Home')}</a>
          <span class="text-muted-foreground opacity-60">→</span>
          <span class="font-medium text-foreground">{t(localeMessages, 'core.category.label', 'Category')}</span>
        </div>

        <h1 class="mb-4 text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl">{category.name}</h1>

        <div class="text-muted-foreground space-y-2">
          {category.description && <p class="text-base sm:text-lg">{category.description}</p>}
          {!category.description && <p class="text-base sm:text-lg">{pageDescription}</p>}
          <p class="text-sm font-medium text-primary">
            {posts.length} {posts.length === 1
              ? t(localeMessages, 'core.category.postSingular', 'post')
              : t(localeMessages, 'core.category.postPlural', 'posts')}
          </p>
        </div>
      </header>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px]">
        <main class="relative">
          <BlogPostGrid
            posts={posts}
            variant="default"
            showExcerpts={true}
            showTags={true}
            showCategories={false}
          />
        </main>

        <aside class="space-y-6">
          <section class="rounded-2xl border border-border bg-card/70 p-5 shadow-sm">
            <h2 class="text-sm font-semibold uppercase tracking-[0.3em] text-muted-foreground">{t(localeMessages, 'core.category.browseCategories', 'Browse categories')}</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              <a
                href={articlesIndexPath}
                class="inline-flex items-center gap-2 rounded-full border border-border px-3 py-1.5 text-xs font-medium text-muted-foreground transition hover:border-foreground hover:text-foreground"
              >
                {t(localeMessages, 'core.category.allPosts', 'All posts')}
              </a>
              {sidebarCategories.map((item) => (
                <a
                  href={buildLocalizedPath(`/category/${item.slug}/`, locale)}
                  class="inline-flex items-center gap-2 rounded-full border border-border px-3 py-1.5 text-xs font-medium text-muted-foreground transition hover:border-foreground hover:text-foreground"
                >
                  #{item.name}
                </a>
              ))}
            </div>
          </section>

          <section class="rounded-2xl border border-border bg-card/70 p-5 shadow-sm">
            <h2 class="text-sm font-semibold uppercase tracking-[0.3em] text-muted-foreground">{t(localeMessages, 'core.category.overviewTitle', 'Need an overview?')}</h2>
            <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
              {t(localeMessages, 'core.category.overviewBody', 'Visit our main archive to explore tags, series, and seasonal guides curated by the newsroom.')}
            </p>
            <a
              href={articlesIndexPath}
              class="mt-4 inline-flex items-center gap-2 rounded-full bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition hover:bg-primary/90"
            >
              {t(localeMessages, 'core.category.overviewCta', 'Browse all stories')}
              <span aria-hidden="true">→</span>
            </a>
          </section>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
