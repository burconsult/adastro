---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogPostGrid from "@/components/BlogPostGrid.astro";
import ResponsiveImage from "@/components/ResponsiveImage.astro";
import { AuthorRepository } from "@/lib/database/repositories/author-repository.js";
import { PostRepository } from "@/lib/database/repositories/post-repository.js";
import { getSiteContentPreferences, getSiteIdentity, getSiteLocaleConfig } from "@/lib/site-config";
import { normalizeLocaleCode } from "@/lib/i18n/locales";
import { getLocaleMessages, t } from "@/lib/i18n/runtime";

const rawLocale = Astro.params.locale || '';
const localeConfig = await getSiteLocaleConfig();
const locale = normalizeLocaleCode(rawLocale, localeConfig.defaultLocale);
if (!localeConfig.locales.includes(locale) || rawLocale !== locale) {
  return new Response(null, { status: 404 });
}
const localeMessages = getLocaleMessages(locale);

const { slug } = Astro.params;
const authorRepo = new AuthorRepository();
const postRepo = new PostRepository();
const contentPreferences = await getSiteContentPreferences();

let author = await authorRepo.findBySlug(slug!);
if (!author) {
  author = await authorRepo.findById(slug!);
}

if (!author) {
  return Astro.redirect('/404');
}

const posts = await postRepo.findWithFilters({
  status: 'published',
  authorId: author.id,
  locale,
  limit: contentPreferences.postsPerPage,
  offset: 0
});

posts.sort((a, b) => {
  const aDate = a.publishedAt || a.createdAt;
  const bDate = b.publishedAt || b.createdAt;
  return bDate.getTime() - aDate.getTime();
});

const siteIdentity = await getSiteIdentity();
const description = author.bio || `${t(localeMessages, 'core.author.descriptionPrefix', 'Posts written by')} ${author.name}.`;
---
<BaseLayout title={`${author.name} — ${siteIdentity.title}`} description={description}>
  <section class="relative overflow-hidden">
    <div class="absolute -top-24 left-0 h-[280px] w-[280px] rounded-full bg-gradient-to-br from-primary/20 via-background to-transparent blur-3xl"></div>
    <div class="absolute -bottom-24 right-0 h-[280px] w-[280px] rounded-full bg-gradient-to-tr from-accent/30 via-background to-transparent blur-3xl"></div>
    <div class="relative mx-auto max-w-5xl px-6 py-16 sm:px-8 sm:py-20">
      <div class="flex flex-col gap-6 rounded-3xl border border-border/70 bg-background/85 p-6 shadow-lg backdrop-blur sm:flex-row sm:items-center sm:gap-8">
        {author.avatar?.url ? (
          <div class="h-20 w-20 shrink-0 overflow-hidden rounded-full border border-border/70 bg-card">
            <ResponsiveImage
              src={author.avatar.url}
              alt={`${author.name} avatar`}
              width={80}
              height={80}
              class="h-full w-full object-cover"
              sizes="80px"
              loading="lazy"
            />
          </div>
        ) : (
          <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full border border-border/70 bg-muted text-xl font-semibold text-muted-foreground">
            {author.name.charAt(0)}
          </div>
        )}
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-primary">{t(localeMessages, 'core.author.label', 'Author')}</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
            {author.name}
          </h1>
          {author.bio && (
            <p class="mt-3 max-w-2xl text-base text-muted-foreground">
              {author.bio}
            </p>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-16 sm:px-8 sm:pb-20">
    <BlogPostGrid
      posts={posts}
      variant="default"
      showExcerpts={true}
      showTags={true}
      showCategories={true}
    />
  </section>
</BaseLayout>
