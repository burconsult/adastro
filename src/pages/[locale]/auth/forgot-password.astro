---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleMessages, t } from "@/lib/i18n/runtime";
import { getSiteLocaleConfig } from "@/lib/site-config";
import { buildLocalizedPath, normalizeLocaleCode } from "@/lib/i18n/locales";
import forgotPasswordScriptUrl from "@/lib/client/auth/forgot-password.js?url";

const localeConfig = await getSiteLocaleConfig();
const locale = normalizeLocaleCode(Astro.locals.locale, localeConfig.defaultLocale);
const localeMessages = getLocaleMessages(locale);
const localizedLoginPath = buildLocalizedPath('/auth/login', locale);
const forgotPasswordClientMessages = {
  sendFailed: t(localeMessages, 'core.auth.forgot.sendFailed', 'Unable to send reset link right now.'),
  failedTitle: t(localeMessages, 'core.auth.forgot.failedTitle', 'Reset failed'),
  successTitle: t(localeMessages, 'core.auth.forgot.successTitle', 'Check your inbox'),
  defaultSuccess: t(localeMessages, 'core.auth.forgot.defaultSuccess', 'If an account exists, a reset link was sent.')
};
---

<BaseLayout
  title={t(localeMessages, 'core.auth.forgot.title', 'Forgot password')}
  description={t(localeMessages, 'core.auth.forgot.description', 'Request a password reset link')}
>
  <div class="min-h-[calc(100vh-8rem)] flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <div class="card p-8">
        <div class="text-center mb-6">
          <img src="/logo.svg" alt="" class="h-12 w-12 mx-auto mb-4" />
          <h1 class="text-2xl font-bold">{t(localeMessages, 'core.auth.forgot.heading', 'Reset your password')}</h1>
          <p class="text-muted-foreground mt-2 text-sm">
            {t(localeMessages, 'core.auth.forgot.body', 'Enter your email and we will send a secure reset link.')}
          </p>
        </div>

        <form id="forgot-password-form" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium mb-2">{t(localeMessages, 'core.auth.forgot.email', 'Email')}</label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              class="w-full px-3 py-2 border border-input rounded-md focus:outline-none focus:ring-2 focus:ring-ring"
              placeholder="you@example.com"
            />
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full btn btn-primary"
          >
            <span id="submit-text">{t(localeMessages, 'core.auth.forgot.submit', 'Send reset link')}</span>
            <span id="submit-loading" class="hidden">{t(localeMessages, 'core.auth.forgot.submitting', 'Sending...')}</span>
          </button>
        </form>

        <p id="forgot-password-status" class="mt-4 text-sm text-muted-foreground hidden"></p>

        <div class="mt-6 text-center">
          <a href={localizedLoginPath} class="text-sm text-muted-foreground hover:text-foreground">
            ← {t(localeMessages, 'core.auth.forgot.backToLogin', 'Back to login')}
          </a>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" id="auth-forgot-messages" set:html={JSON.stringify(forgotPasswordClientMessages)}></script>
  <script type="module" src={forgotPasswordScriptUrl}></script>
</BaseLayout>
