---
import ResponsiveImage from './ResponsiveImage.astro';
import type { BlogPost } from '@/lib/types/index.js';
import { getSiteContentPreferences, getSiteContentRouting } from '@/lib/site-config';
import { buildArticlePostPath } from '@/lib/routing/articles';
import { buildLocalizedPath } from '@/lib/i18n/locales';

export interface Props {
  post: BlogPost;
  variant?: 'default' | 'compact' | 'featured';
  showExcerpt?: boolean;
  showTags?: boolean;
  showCategories?: boolean;
}

const {
  post,
  variant = 'default',
  showExcerpt = true,
  showTags = true,
  showCategories = false
} = Astro.props;
const contentRouting = await getSiteContentRouting();
const contentPreferences = await getSiteContentPreferences();
const postHref = buildArticlePostPath(post.slug, post.publishedAt || post.createdAt, {
  basePath: contentRouting.articleBasePath,
  permalinkStyle: contentRouting.articlePermalinkStyle,
  localePrefix: post.locale
});
const excerptLimit = contentPreferences.excerptLength;
const excerptText = typeof post.excerpt === 'string' ? post.excerpt.trim() : '';
const excerpt = excerptText.length > excerptLimit
  ? `${excerptText.slice(0, Math.max(0, excerptLimit - 1)).trimEnd()}…`
  : excerptText;

const intrinsicDimensions = post.featuredImage?.dimensions || post.featuredImage?.originalDimensions;
const fallbackDimensions = variant === 'featured'
  ? { width: 2100, height: 900 }
  : variant === 'compact'
    ? { width: 900, height: 900 }
    : { width: 1280, height: 720 };
const imageWidth = intrinsicDimensions?.width || fallbackDimensions.width;
const imageHeight = intrinsicDimensions?.height || fallbackDimensions.height;
const titleClampClass = variant === 'featured' ? 'line-clamp-3' : 'line-clamp-2';

const cardClasses = {
  default: 'blog-post-card',
  compact: 'blog-post-card blog-post-card--compact',
  featured: 'blog-post-card blog-post-card--featured'
};
---

<article class={`group blog-post-card-shell relative block h-full overflow-hidden rounded-2xl border border-border/80 bg-card shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg focus-within:ring-2 focus-within:ring-ring/40 motion-reduce:transition-none motion-reduce:hover:transform-none ${variant === 'featured' ? 'md:col-span-2' : ''} ${variant === 'compact' ? 'sm:flex' : ''}`}>
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-accent/20 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
  <div class="blog-post-card-inner relative h-full overflow-hidden rounded-2xl bg-card">
    <div class={`flex h-full ${variant === 'compact' ? 'sm:flex-row' : 'flex-col'}`}>
      <!-- Featured Image -->
        <div class={`relative overflow-hidden ${variant === 'compact' ? 'sm:w-1/3 sm:aspect-square' : variant === 'featured' ? 'aspect-[21/9]' : 'aspect-video'}`}>
          <a href={postHref} data-astro-prefetch="viewport" class="block w-full h-full">
            <ResponsiveImage
              src={post.featuredImage?.url || '/images/article_image_01.webp'}
              alt={post.featuredImage?.altText || `Featured image for ${post.title}`}
              width={imageWidth}
              height={imageHeight}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105 motion-reduce:transition-none"
              loading="lazy"
              priority={variant === 'featured'}
              sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
            />
          </a>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-slate-950/30 to-transparent"></div>
        
        <!-- Mobile-optimized overlay content -->
        <div class="absolute bottom-0 left-0 right-0 p-4 text-white">
          <div class="flex flex-wrap items-center gap-2 text-xs text-white/80 mb-2">
            <span>By {post.author.name}</span>
            <span>•</span>
            <span>{(post.publishedAt || post.createdAt).toLocaleDateString()}</span>
          </div>
          <h2 class={`font-semibold leading-tight break-words ${titleClampClass} ${variant === 'featured' ? 'text-2xl md:text-3xl' : variant === 'compact' ? 'text-lg' : 'text-xl'}`}>
            <a href={postHref} data-astro-prefetch="hover" class="hover:underline focus:underline focus:outline-none">
              {post.title}
            </a>
          </h2>
        </div>
      </div>

      <!-- Post Content -->
      <div class={`blog-post-card-content flex h-full flex-1 flex-col gap-3 p-4 sm:p-5 lg:p-6 ${variant === 'compact' ? 'sm:w-2/3' : ''}`}>
        {showExcerpt && excerpt && (
          <p class={`line-clamp-3 text-muted-foreground leading-relaxed ${variant === 'featured' ? 'text-base' : 'text-sm'}`}>{excerpt}</p>
        )}

        <!-- Categories -->
        {showCategories && post.categories && post.categories.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.categories.map((category) => (
              <a href={buildLocalizedPath(`/category/${category.slug}/`, post.locale)} data-astro-prefetch="hover" class="badge badge-secondary hover:bg-secondary/80 transition-colors">
                {category.name}
              </a>
            ))}
          </div>
        )}

        <!-- Tags -->
        {showTags && post.tags && post.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.tags.map((tag) => (
              <a href={buildLocalizedPath(`/tag/${tag.slug}/`, post.locale)} data-astro-prefetch="hover" class="badge hover:bg-accent hover:text-accent-foreground transition-colors">
                #{tag.name}
              </a>
            ))}
          </div>
        )}

        <!-- Read More Button -->
        <div class="blog-post-card-read-more-wrap mt-auto pt-2">
          <a href={postHref} data-astro-prefetch="hover" class="blog-post-card-read-more inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring h-9 px-4 py-2 bg-primary text-primary-foreground hover:bg-primary/90 sm:w-auto w-full">
            Read more
            <span class="sr-only">about {post.title}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  /* Screen reader only content */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Touch-friendly interactions */
  @media (hover: none) and (pointer: coarse) {
    .group:hover {
      transform: none;
    }
    
    .group:active {
      transform: scale(0.98);
    }
  }
</style>
