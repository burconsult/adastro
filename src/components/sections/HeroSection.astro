---
import { applyArticleBasePathToHref } from "@/lib/routing/articles";
import { localizeHref } from "@/lib/i18n/locales";

const { content = {} } = Astro.props as { content?: Record<string, any> };
const articleBasePath = typeof Astro.props.articleBasePath === 'string' ? Astro.props.articleBasePath : undefined;
const localePrefix = typeof Astro.locals.locale === 'string' ? Astro.locals.locale : undefined;
const label = typeof content.label === 'string' ? content.label : '';
const heading = typeof content.heading === 'string' ? content.heading : '';
const subheading = typeof content.subheading === 'string' ? content.subheading : '';
const primaryLabel = typeof content.primaryCtaLabel === 'string' ? content.primaryCtaLabel : '';
const rawPrimaryHref = typeof content.primaryCtaHref === 'string' ? content.primaryCtaHref : '';
const secondaryLabel = typeof content.secondaryCtaLabel === 'string' ? content.secondaryCtaLabel : '';
const rawSecondaryHref = typeof content.secondaryCtaHref === 'string' ? content.secondaryCtaHref : '';
const primaryHref = rawPrimaryHref
  ? localizeHref(
      applyArticleBasePathToHref(rawPrimaryHref, { basePath: articleBasePath, localePrefix }),
      localePrefix || 'en',
      { skipPrefixes: ['/admin', '/api', '/auth', '/setup', '/profile', '/mcp'] }
    )
  : '';
const secondaryHref = rawSecondaryHref
  ? localizeHref(
      applyArticleBasePathToHref(rawSecondaryHref, { basePath: articleBasePath, localePrefix }),
      localePrefix || 'en',
      { skipPrefixes: ['/admin', '/api', '/auth', '/setup', '/profile', '/mcp'] }
    )
  : '';
const imageUrl = typeof content.imageUrl === 'string' ? content.imageUrl : '';
const imageAlt = typeof content.imageAlt === 'string' ? content.imageAlt : 'Hero image';
const imageWidth = Number.isFinite(Number(content.imageWidth)) ? Number(content.imageWidth) : 1440;
const imageHeight = Number.isFinite(Number(content.imageHeight)) ? Number(content.imageHeight) : 900;
---

<section class="relative overflow-hidden">
  <div
    class="pointer-events-none rounded-full bg-gradient-to-br from-primary/20 via-background to-transparent blur-3xl"
    style="position:absolute;top:-8rem;left:0;width:22.5rem;height:22.5rem;"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none rounded-full bg-gradient-to-tr from-accent/30 via-background to-transparent blur-3xl"
    style="position:absolute;right:0;bottom:-8rem;width:22.5rem;height:22.5rem;"
    aria-hidden="true"
  ></div>
  <div class="relative mx-auto max-w-5xl px-6 py-20 sm:px-8">
    <div class="space-y-6 text-center">
      {label && (
        <span class="text-xs font-semibold uppercase tracking-[0.35em] text-primary">
          {label}
        </span>
      )}
      {heading && (
        <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
          {heading}
        </h1>
      )}
      {subheading && (
        <p class="mx-auto max-w-3xl text-base text-muted-foreground sm:text-lg">
          {subheading}
        </p>
      )}
      {(primaryLabel || secondaryLabel) && (
        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          {primaryLabel && primaryHref && (
            <a
              href={primaryHref}
              class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:bg-primary/90"
            >
              {primaryLabel}
            </a>
          )}
          {secondaryLabel && secondaryHref && (
            <a
              href={secondaryHref}
              class="inline-flex items-center justify-center rounded-full border border-border px-6 py-3 text-sm font-semibold text-foreground transition hover:border-foreground"
            >
              {secondaryLabel}
            </a>
          )}
        </div>
      )}
      {imageUrl && (
        <div
          class="mx-auto mt-8 w-full max-w-2xl overflow-hidden rounded-3xl border border-border/70 bg-background/70 shadow-xl"
          style={`aspect-ratio: ${imageWidth} / ${imageHeight};`}
        >
          <img
            src={imageUrl}
            alt={imageAlt}
            width={imageWidth}
            height={imageHeight}
            class="h-full w-full object-cover"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      )}
    </div>
  </div>
</section>
