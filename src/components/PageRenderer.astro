---
import PageSections from "@/components/PageSections.astro";
import { editorJsToHtml, normalizeEditorJsData } from "@/lib/editorjs";
import { applyArticleBasePathToHref } from "@/lib/routing/articles";
import { getSiteContentRouting } from "@/lib/site-config";
import { sanitizeHtml } from "@/lib/utils/data-transform";
import type { Page } from "@/lib/types";

const { page, showTitle = true } = Astro.props as { page: Page; showTitle?: boolean };
const blocks = normalizeEditorJsData(page.contentBlocks ?? {});
const contentHtml = page.contentHtml || editorJsToHtml(blocks);
const contentRouting = await getSiteContentRouting();
const normalizedContentHtml = contentHtml.replace(/(href=["'])\/blog(\/[^"']*)?(["'])/g, (_match, prefix, suffix = '', suffixQuote) => {
  const href = `/blog${suffix}`;
  const mapped = applyArticleBasePathToHref(href, { basePath: contentRouting.articleBasePath });
  return `${prefix}${mapped}${suffixQuote}`;
});
const safeHtml = sanitizeHtml(normalizedContentHtml);
const hasSections = page.template !== 'default' && (page.sections?.length ?? 0) > 0;
---

{hasSections ? (
  <PageSections sections={page.sections} articleBasePath={contentRouting.articleBasePath} />
) : (
  <section class="mx-auto max-w-3xl px-6 py-16 sm:px-8">
    {showTitle && (
      <header class="mb-8">
        <h1 class="text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
          {page.title}
        </h1>
        {page.excerpt && (
          <p class="mt-3 text-base text-muted-foreground">{page.excerpt}</p>
        )}
      </header>
    )}
    <div class="article-prose prose max-w-none prose-headings:font-semibold prose-a:text-primary" set:html={safeHtml} />
  </section>
)}
